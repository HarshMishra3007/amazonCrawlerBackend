# Neon PostgreSQL — from Neon Console: Project → Connection details → JDBC
# Quote values that contain & or special characters
DB_URL="jdbc:postgresql://ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DB_USER="your_neon_user"
DB_PASSWORD="your_neon_password"

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
CRAWL_CRON=0 0 */6 * * *
CRAWLER_DELAY_MS=2500
CRAWLER_TIMEOUT_MS=30000
AMAZON_BASE_URL=https://www.amazon.in
CORS_ALLOWED_ORIGINS=http://localhost:5173
